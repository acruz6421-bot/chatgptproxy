# ====================================================================
# Configurações do ChatGPTProxy
# Copie este arquivo como '.env' e preencha as credenciais.
# ====================================================================

# Porta onde o servidor proxy rodará
PORT=3500

# Chave de API local para proteger seu proxy. 
# Use-a nas configurações dos seus clientes (ex: Kilo Code, Cline, Continue) como 'api_key'.
API_KEY=chatgpt-local-dev

# Credenciais padrão da conta ChatGPT Web.
# OBS: O script 'login-chatgptproxy.cmd' irá preencher esses campos automaticamente para você!
CHATGPT_ACCESS_TOKEN=
CHATGPT_COOKIE=
CHATGPT_UA=

# (Opcional) Path customizado para o binário do Chromium/Chrome se necessário.
# CHROME_PATH=
